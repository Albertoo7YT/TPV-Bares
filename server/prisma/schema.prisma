generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  WAITER
  KITCHEN
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
}

enum OrderStatus {
  ACTIVE
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

enum IngredientCategory {
  BASE
  SAUCE
  EXTRA
  TOPPING
}

enum OrderItemModificationAction {
  REMOVED
  ADDED
}

enum PaymentMethod {
  CASH
  CARD
  MIXED
}

model Restaurant {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  address       String
  phone         String
  logoUrl       String?
  taxRate       Decimal        @default(10) @db.Decimal(5, 2)
  taxIncluded   Boolean        @default(true)
  currency      String         @default("EUR")
  currencySymbol String        @default("€")
  openingTime   String         @default("10:00")
  closingTime   String         @default("23:00")
  kitchenAlertMinutes Int      @default(10)
  allowTakeaway Boolean        @default(false)
  notificationSounds Boolean   @default(true)
  ticketMessage String?
  relayToken    String?
  autoPrintKitchen Boolean     @default(true)
  autoPrintReceipt Boolean     @default(true)
  printModifications Boolean   @default(true)
  kitchenCopies Int            @default(1)
  ticketWidth Int              @default(80)
  tableZoneOrder String[]      @default([])
  createdAt     DateTime       @default(now())
  users         User[]
  categories    Category[]
  products      Product[]
  ingredients   Ingredient[]
  tables        Table[]
  cashRegisters CashRegister[]
  authorizedDevices AuthorizedDevice[]
}

model User {
  id                  String         @id @default(cuid())
  name                String
  pin                 String         @db.VarChar(4)
  role                UserRole
  restaurantId        String
  active              Boolean        @default(true)
  createdAt           DateTime       @default(now())
  restaurant          Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders              Order[]        @relation("OrderWaiter")
  openedCashRegisters CashRegister[] @relation("CashRegisterOpenedBy")
  closedCashRegisters CashRegister[] @relation("CashRegisterClosedBy")

  @@unique([restaurantId, pin])
  @@index([restaurantId])
}

model Category {
  id           String     @id @default(cuid())
  name         String
  order        Int
  restaurantId String
  active       Boolean    @default(true)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([restaurantId, name])
  @@index([restaurantId, order])
}

model Product {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  imageUrl           String?
  price              Decimal             @db.Decimal(10, 2)
  categoryId         String
  restaurantId       String
  available          Boolean             @default(true)
  createdAt          DateTime            @default(now())
  category           Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  restaurant         Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems         OrderItem[]
  productIngredients ProductIngredient[]

  @@index([categoryId])
  @@index([restaurantId])
}

model Ingredient {
  id                 String                  @id @default(cuid())
  name               String
  category           IngredientCategory
  extraPrice         Decimal                 @default(0) @db.Decimal(10, 2)
  available          Boolean                 @default(true)
  order              Int                     @default(0)
  restaurantId       String
  restaurant         Restaurant              @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  productIngredients ProductIngredient[]
  modifications      OrderItemModification[]

  @@unique([restaurantId, name])
  @@index([restaurantId, category, order])
}

model ProductIngredient {
  id           String     @id @default(cuid())
  productId    String
  ingredientId String
  isDefault    Boolean    @default(true)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
  @@index([productId])
  @@index([ingredientId])
}

model Table {
  id           String      @id @default(cuid())
  number       Int
  name         String?
  zone         String      @default("Interior")
  capacity     Int
  restaurantId String
  status       TableStatus @default(FREE)
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders       Order[]
  bills        Bill[]

  @@unique([restaurantId, number])
  @@index([restaurantId, status])
}

model Order {
  id        String      @id @default(cuid())
  tableId   String
  waiterId  String
  billId    String?
  status    OrderStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  table     Table       @relation(fields: [tableId], references: [id], onDelete: Restrict)
  waiter    User        @relation("OrderWaiter", fields: [waiterId], references: [id], onDelete: Restrict)
  bill      Bill?       @relation(fields: [billId], references: [id], onDelete: SetNull)
  items     OrderItem[]

  @@index([tableId])
  @@index([waiterId])
  @@index([billId])
  @@index([status])
}

model OrderItem {
  id            String                  @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  unitPrice     Decimal                 @db.Decimal(10, 2)
  notes         String?
  status        OrderItemStatus         @default(PENDING)
  order         Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product                 @relation(fields: [productId], references: [id], onDelete: Restrict)
  modifications OrderItemModification[]

  @@index([orderId])
  @@index([productId])
  @@index([status])
}

model OrderItemModification {
  id           String                      @id @default(cuid())
  orderItemId  String
  ingredientId String
  action       OrderItemModificationAction
  extraPrice   Decimal                     @default(0) @db.Decimal(10, 2)
  orderItem    OrderItem                   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  ingredient   Ingredient                  @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@index([orderItemId])
  @@index([ingredientId])
}

model Bill {
  id            String         @id @default(cuid())
  tableId        String
  subtotal      Decimal        @db.Decimal(10, 2)
  tax           Decimal        @db.Decimal(10, 2)
  total         Decimal        @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  paidAt        DateTime
  createdAt     DateTime       @default(now())
  cashAmount    Decimal?       @db.Decimal(10, 2)
  cardAmount    Decimal?       @db.Decimal(10, 2)
  table         Table          @relation(fields: [tableId], references: [id], onDelete: Restrict)
  orders        Order[]

  @@index([tableId])
  @@index([paidAt])
}

model CashRegister {
  id           String     @id @default(cuid())
  restaurantId String
  openedById   String
  closedById   String?
  openedAt     DateTime   @default(now())
  closedAt     DateTime?
  initialCash  Decimal    @db.Decimal(10, 2)
  totalCash    Decimal    @db.Decimal(10, 2) @default(0)
  totalCard    Decimal    @db.Decimal(10, 2) @default(0)
  totalSales   Decimal    @db.Decimal(10, 2) @default(0)
  realCash     Decimal?   @db.Decimal(10, 2)
  difference   Decimal?   @db.Decimal(10, 2)
  notes        String?
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  openedBy     User       @relation("CashRegisterOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  closedBy     User?      @relation("CashRegisterClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([openedById])
  @@index([closedById])
}

model AuthorizedDevice {
  id           String     @id @default(cuid())
  restaurantId String
  deviceToken  String     @unique
  deviceName   String
  userAgent    String
  lastUsed     DateTime   @default(now())
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, active])
  @@index([lastUsed])
}
